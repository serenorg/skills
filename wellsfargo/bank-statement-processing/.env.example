# Optional override: explicit SERENDB connection string for persistence.
# If empty, scripts/run.py resolves this automatically from your logged-in
# Seren CLI/MCP context via `seren env init`.
# Example: postgresql://user:pass@host:5432/alpaca_short_bot
WF_SERENDB_URL=

# Optional explicit path to SerenDesktop Playwright MCP script.
# If empty, scripts/run.py auto-detects common SerenDesktop locations.
# Example:
# PLAYWRIGHT_MCP_SCRIPT=/Applications/SerenDesktop.app/Contents/Resources/embedded-runtime/mcp-servers/playwright-stealth/dist/index.js
PLAYWRIGHT_MCP_SCRIPT=

# Optional: LLM fallback endpoint for uncategorized transactions.
WF_LLM_ENDPOINT=

# Optional: API key used by WF_LLM_ENDPOINT (if required).
WF_LLM_API_KEY=
